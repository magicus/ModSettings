{
  "schemaVersion": 1,
  "id": "modsettings",
  "version": "${version}",

  "name": "ModSettings",
  "description": "Provides an easy to access configuration screen for all installed mods",
  "authors": [
    "magicus"
  ],
  "contact": {
    "homepage": "https://github.com/magicus/modsettings",
    "issues": "https://github.com/magicus/modsettings/issues",
    "sources": "https://github.com/magicus/modsettings"
  },

  "license": "MIT",
  "icon": "assets/modsettings/icon.png",

  "environment": "client",

  "entrypoints": {
    "client": [
      "se.icus.mag.modsettings.Main"
    ]
  },

  "mixins": [
    "modsettings.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=${fabric_api_version}",
    "minecraft": "${supported_minecraft_versions}"
  }
}
